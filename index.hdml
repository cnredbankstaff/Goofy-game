<!doctype html><!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Potato Apocalypse</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Bungee+Shade&family=Fredoka:wght@400;600;700&display=swap');

    html, body { height: 100%; margin: 0; overflow: hidden; }

    .game-bg {
      background: linear-gradient(180deg, #43e97b 0%, #38f9d7 30%, #a8edea 60%, #fed6e3 100%);
      width: 100%;
      height: 100%;
      position: relative;
    }

    .potato {
      position: absolute;
      font-size: 40px;
      transition: transform 0.05s;
      filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));
      z-index: 50;
    }

    .potato.hit {
      animation: potatoHit 0.5s ease;
    }

    .potato.shielded::after {
      content: '';
      position: absolute;
      top: -12px; left: -12px; right: -12px; bottom: -12px;
      border-radius: 50%;
      border: 3px solid #00d4ff;
      background: radial-gradient(circle, rgba(0,212,255,0.15) 0%, rgba(0,212,255,0.05) 100%);
      animation: shieldPulse 1s infinite;
    }

    @keyframes potatoHit {
      0%, 100% { transform: scale(1) rotate(0deg); }
      25% { transform: scale(1.3) rotate(-15deg); }
      50% { transform: scale(0.8) rotate(15deg); }
      75% { transform: scale(1.1) rotate(-5deg); }
    }

    @keyframes shieldPulse {
      0%, 100% { opacity: 0.7; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.08); }
    }

    .enemy {
      position: absolute;
      font-size: 32px;
      z-index: 30;
      filter: drop-shadow(0 3px 4px rgba(0,0,0,0.25));
    }

    .enemy.exploding {
      animation: explode 0.4s ease forwards;
    }

    @keyframes explode {
      0% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.8) rotate(180deg); opacity: 0.6; }
      100% { transform: scale(0); opacity: 0; }
    }

    .powerup {
      position: absolute;
      font-size: 28px;
      z-index: 40;
      animation: powerupBob 1s ease-in-out infinite;
      filter: drop-shadow(0 0 10px rgba(255,255,0,0.6));
    }

    @keyframes powerupBob {
      0%, 100% { transform: translateY(0) scale(1); }
      50% { transform: translateY(-8px) scale(1.1); }
    }

    .scream-text {
      position: absolute;
      font-family: 'Bungee Shade', cursive;
      color: #ff3366;
      font-size: 18px;
      pointer-events: none;
      z-index: 60;
      animation: screamFloat 0.8s ease forwards;
      text-shadow: 2px 2px 0 #ffdd00;
    }

    @keyframes screamFloat {
      0% { opacity: 1; transform: translateY(0) scale(1); }
      100% { opacity: 0; transform: translateY(-60px) scale(1.4); }
    }

    .powerup-text {
      position: absolute;
      font-family: 'Fredoka', sans-serif;
      font-weight: 700;
      color: #00ff88;
      font-size: 16px;
      pointer-events: none;
      z-index: 60;
      animation: powerupFloat 1s ease forwards;
      text-shadow: 1px 1px 0 #003322;
    }

    @keyframes powerupFloat {
      0% { opacity: 1; transform: translateY(0) scale(1); }
      100% { opacity: 0; transform: translateY(-50px) scale(1.3); }
    }

    .hud {
      position: absolute;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 20px;
      background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, transparent 100%);
      font-family: 'Fredoka', sans-serif;
    }

    .timer-display {
      font-family: 'Bungee Shade', cursive;
      font-size: 28px;
      color: #ffdd00;
      text-shadow: 2px 2px 0 #ff3366, -1px -1px 0 #003322;
    }

    .hearts { font-size: 28px; }
    .heart-lost { opacity: 0.25; transition: opacity 0.3s; }

    .speed-indicator {
      font-size: 13px;
      color: #fff;
      background: rgba(255,51,102,0.7);
      padding: 2px 10px;
      border-radius: 20px;
      font-weight: 600;
    }

    .overlay {
      position: absolute;
      inset: 0;
      z-index: 200;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(6px);
      font-family: 'Fredoka', sans-serif;
    }

    .overlay h1 {
      font-family: 'Bungee Shade', cursive;
      font-size: clamp(24px, 5vw, 48px);
      text-align: center;
      line-height: 1.3;
    }

    .btn-play {
      padding: 14px 40px;
      font-family: 'Fredoka', sans-serif;
      font-weight: 700;
      font-size: 22px;
      border: none;
      border-radius: 50px;
      cursor: pointer;
      transition: transform 0.15s, box-shadow 0.15s;
      box-shadow: 0 6px 0 rgba(0,0,0,0.3);
    }

    .btn-play:hover { transform: translateY(-2px); box-shadow: 0 8px 0 rgba(0,0,0,0.3); }
    .btn-play:active { transform: translateY(2px); box-shadow: 0 2px 0 rgba(0,0,0,0.3); }

    .ground {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 60px;
      background: linear-gradient(180deg, #7ec850 0%, #5da03a 100%);
      z-index: 10;
      border-top: 4px solid #4a8a2e;
    }

    .ground::before {
      content: '';
      position: absolute;
      top: -8px; left: 0; right: 0; height: 16px;
      background: repeating-linear-gradient(90deg, transparent 0, transparent 30px, #6db845 30px, #6db845 32px);
    }

    .active-powerup-badge {
      position: absolute;
      bottom: 70px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 90;
      font-family: 'Fredoka', sans-serif;
      font-weight: 700;
      font-size: 14px;
      padding: 4px 14px;
      border-radius: 20px;
      color: #fff;
      animation: badgePulse 0.6s infinite;
    }

    @keyframes badgePulse {
      0%, 100% { transform: translateX(-50%) scale(1); }
      50% { transform: translateX(-50%) scale(1.05); }
    }

    .confetti {
      position: absolute;
      width: 8px; height: 8px;
      z-index: 150;
      border-radius: 2px;
      animation: confettiFall linear forwards;
    }

    @keyframes confettiFall {
      0% { opacity: 1; transform: translateY(0) rotate(0deg); }
      100% { opacity: 0; transform: translateY(300px) rotate(720deg); }
    }
  </style>
  <style>body { box-sizing: border-box; }</style>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js" type="text/javascript"></script>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
 </head>
 <body class="h-full">
  <div id="game-container" class="game-bg"><!-- HUD -->
   <header class="hud" id="hud" style="display:none;">
    <div class="hearts" id="hearts" aria-label="Health">
     ❤️❤️❤️
    </div>
    <div class="timer-display" id="timer">
     60
    </div>
    <div class="speed-indicator" id="speed-badge">
     PHASE 1
    </div>
   </header><!-- Ground -->
   <div class="ground"></div><!-- Player -->
   <div id="potato" class="potato" style="display:none;" aria-label="Player potato">
    🥔
   </div><!-- Start Screen -->
   <div id="start-screen" class="overlay">
    <h1 id="title-text" style="color:#ffdd00; text-shadow: 3px 3px 0 #ff3366;">🥔 POTATO<br>
      APOCALYPSE</h1>
    <p style="color:#fff; font-size:18px; margin: 12px 0 4px; font-family:'Fredoka',sans-serif;">Survive 60 seconds of pure chaos!</p>
    <p style="color:#a8edea; font-size:14px; margin-bottom:24px; font-family:'Fredoka',sans-serif;">Arrow keys / WASD to move</p><button class="btn-play" id="start-btn" style="background:#ff3366; color:#fff;" onclick="startGame()">LET'S GO! 🎮</button>
   </div><!-- Game Over Screen -->
   <div id="gameover-screen" class="overlay" style="display:none;">
    <h1 style="color:#ff3366;">💥 GAME OVER 💥</h1>
    <p id="gameover-subtext" style="color:#fff; font-size:20px; margin:12px 0 24px; font-family:'Fredoka',sans-serif;">The potato has been mashed...</p><button class="btn-play" style="background:#ff3366; color:#fff;" onclick="startGame()">TRY AGAIN 🥔</button>
   </div><!-- Victory Screen -->
   <div id="victory-screen" class="overlay" style="display:none;">
    <h1 id="victory-text" style="color:#ffdd00; text-shadow: 3px 3px 0 #ff3366;">🏆 YOU SURVIVED THE POTATO APOCALYPSE! 🏆</h1>
    <p style="color:#fff; font-size:20px; margin:12px 0; font-family:'Fredoka',sans-serif;">You are the ultimate spud!</p>
    <div style="font-size:60px; margin:8px 0;">
     🥔👑
    </div><button class="btn-play" style="background:#00cc66; color:#fff; margin-top:16px;" onclick="startGame()">PLAY AGAIN 🎮</button>
   </div>
  </div>
  <script>
    // ── Config & SDK ──
    const defaultConfig = {
      game_title: 'POTATO APOCALYPSE',
      victory_message: 'YOU SURVIVED THE POTATO APOCALYPSE!',
      background_color: '#43e97b',
      surface_color: '#1a1a2e',
      text_color: '#ffdd00',
      primary_action_color: '#ff3366',
      secondary_action_color: '#00cc66',
      font_family: 'Fredoka',
      font_size: 16
    };

    function applyConfig(cfg) {
      const c = { ...defaultConfig, ...cfg };
      const font = c.font_family || defaultConfig.font_family;
      const base = c.font_size || defaultConfig.font_size;

      const titleEl = document.getElementById('title-text');
      if (titleEl) {
        titleEl.textContent = '🥔 ' + (c.game_title || defaultConfig.game_title);
        titleEl.style.color = c.text_color;
        titleEl.style.textShadow = `3px 3px 0 ${c.primary_action_color}`;
        titleEl.style.fontFamily = `'Bungee Shade', ${font}, cursive`;
      }

      const victoryEl = document.getElementById('victory-text');
      if (victoryEl) {
        victoryEl.textContent = '🏆 ' + (c.victory_message || defaultConfig.victory_message) + ' 🏆';
        victoryEl.style.color = c.text_color;
        victoryEl.style.textShadow = `3px 3px 0 ${c.primary_action_color}`;
        victoryEl.style.fontFamily = `'Bungee Shade', ${font}, cursive`;
      }

      const container = document.getElementById('game-container');
      if (container) {
        container.style.background = `linear-gradient(180deg, ${c.background_color} 0%, ${c.secondary_action_color}44 50%, ${c.primary_action_color}22 100%)`;
      }

      document.querySelectorAll('.btn-play').forEach(btn => {
        btn.style.fontFamily = `${font}, sans-serif`;
        btn.style.fontSize = `${base * 1.375}px`;
      });

      document.querySelectorAll('.overlay p').forEach(p => {
        p.style.fontFamily = `${font}, sans-serif`;
      });

      const timer = document.getElementById('timer');
      if (timer) timer.style.color = c.text_color;

      const speedBadge = document.getElementById('speed-badge');
      if (speedBadge) {
        speedBadge.style.background = `${c.primary_action_color}b3`;
        speedBadge.style.fontFamily = `${font}, sans-serif`;
      }
    }

    if (window.elementSdk) {
      window.elementSdk.init({
        defaultConfig,
        onConfigChange: async (cfg) => applyConfig(cfg),
        mapToCapabilities: (cfg) => ({
          recolorables: [
            { get: () => cfg.background_color || defaultConfig.background_color, set: v => { cfg.background_color = v; window.elementSdk.setConfig({ background_color: v }); } },
            { get: () => cfg.surface_color || defaultConfig.surface_color, set: v => { cfg.surface_color = v; window.elementSdk.setConfig({ surface_color: v }); } },
            { get: () => cfg.text_color || defaultConfig.text_color, set: v => { cfg.text_color = v; window.elementSdk.setConfig({ text_color: v }); } },
            { get: () => cfg.primary_action_color || defaultConfig.primary_action_color, set: v => { cfg.primary_action_color = v; window.elementSdk.setConfig({ primary_action_color: v }); } },
            { get: () => cfg.secondary_action_color || defaultConfig.secondary_action_color, set: v => { cfg.secondary_action_color = v; window.elementSdk.setConfig({ secondary_action_color: v }); } }
          ],
          borderables: [],
          fontEditable: {
            get: () => cfg.font_family || defaultConfig.font_family,
            set: v => { cfg.font_family = v; window.elementSdk.setConfig({ font_family: v }); }
          },
          fontSizeable: {
            get: () => cfg.font_size || defaultConfig.font_size,
            set: v => { cfg.font_size = v; window.elementSdk.setConfig({ font_size: v }); }
          }
        }),
        mapToEditPanelValues: (cfg) => new Map([
          ['game_title', cfg.game_title || defaultConfig.game_title],
          ['victory_message', cfg.victory_message || defaultConfig.victory_message]
        ])
      });
    }
    applyConfig(defaultConfig);

    // ── Game State ──
    let gameRunning = false;
    let gameTime = 60;
    let health = 3;
    let playerX = 0, playerY = 0;
    let playerW = 40, playerH = 40;
    let playerSpeed = 5;
    let baseSpeed = 5;
    let keys = {};
    let enemies = [];
    let powerups = [];
    let activePowerups = { speed: 0, shield: false, freeze: 0 };
    let spawnRate = 1200;
    let phase = 1;
    let gameLoop = null;
    let timerInterval = null;
    let spawnInterval = null;
    let powerupInterval = null;
    let animFrame = null;

    const container = document.getElementById('game-container');
    const potato = document.getElementById('potato');
    const timerEl = document.getElementById('timer');
    const heartsEl = document.getElementById('hearts');
    const hudEl = document.getElementById('hud');
    const speedBadge = document.getElementById('speed-badge');

    const ENEMY_TYPES = [
      { emoji: '🍕', name: 'pizza', size: 34 },
      { emoji: '🦆', name: 'duck', size: 32 },
      { emoji: '🍌', name: 'banana', size: 30 },
      { emoji: '🧦', name: 'sock', size: 36 },
      { emoji: '🌭', name: 'hotdog', size: 32 },
      { emoji: '🎳', name: 'bowling', size: 34 },
      { emoji: '👟', name: 'shoe', size: 30 }
    ];

    const POWERUP_TYPES = [
      { emoji: '👟', name: 'speed', color: '#00ccff', label: '⚡ SPEED BOOST!' },
      { emoji: '🛡️', name: 'shield', color: '#00ff88', label: '🛡️ SHIELD!' },
      { emoji: '⏸️', name: 'freeze', color: '#cc66ff', label: '❄️ TIME FREEZE!' }
    ];

    const SCREAMS = ['AAAH!', 'OOF!', 'OUCH!', 'NOOO!', 'WHY?!', 'HELP!', 'SPLAT!'];

    function startGame() {
      // Clean up
      document.querySelectorAll('.enemy, .powerup, .scream-text, .powerup-text, .active-powerup-badge, .confetti').forEach(el => el.remove());
      clearInterval(timerInterval);
      clearInterval(spawnInterval);
      clearInterval(powerupInterval);
      cancelAnimationFrame(animFrame);

      gameRunning = true;
      gameTime = 60;
      health = 3;
      enemies = [];
      powerups = [];
      activePowerups = { speed: 0, shield: false, freeze: 0 };
      playerSpeed = baseSpeed = 5;
      spawnRate = 1200;
      phase = 1;
      keys = {};

      const rect = container.getBoundingClientRect();
      playerX = rect.width / 2 - 20;
      playerY = rect.height - 110;

      document.getElementById('start-screen').style.display = 'none';
      document.getElementById('gameover-screen').style.display = 'none';
      document.getElementById('victory-screen').style.display = 'none';
      hudEl.style.display = 'flex';
      potato.style.display = 'block';

      updateHearts();
      updateTimer();
      updatePhase();

      timerInterval = setInterval(() => {
        if (!gameRunning) return;
        gameTime--;
        updateTimer();
        if (gameTime <= 0) victory();
        if (gameTime === 45 || gameTime === 30 || gameTime === 15) escalate();
      }, 1000);

      spawnInterval = setInterval(spawnEnemy, spawnRate);
      powerupInterval = setInterval(spawnPowerup, 6000);

      animFrame = requestAnimationFrame(update);
    }

    function escalate() {
      phase++;
      spawnRate = Math.max(80, spawnRate - 380);
      clearInterval(spawnInterval);
      spawnInterval = setInterval(spawnEnemy, spawnRate);
      baseSpeed += 1.3;
      if (!activePowerups.speed) playerSpeed = baseSpeed;
      
      // Escalating enemy waves - spawn MORE enemies each phase
      if (phase > 1) {
        const waveCount = phase === 2 ? 4 : phase === 3 ? 6 : 8;
        for (let i = 0; i < waveCount; i++) {
          setTimeout(spawnEnemy, i * 120);
        }
      }
      updatePhase();
    }

    function updatePhase() {
      const labels = ['PHASE 1', 'PHASE 2 🔥', 'PHASE 3 🔥🔥', 'PHASE 4 💀'];
      speedBadge.textContent = labels[phase - 1] || 'MAX CHAOS 💀🔥';
    }

    function updateHearts() {
      heartsEl.innerHTML = '';
      for (let i = 0; i < 3; i++) {
        const span = document.createElement('span');
        span.textContent = '❤️';
        if (i >= health) span.classList.add('heart-lost');
        heartsEl.appendChild(span);
      }
    }

    function updateTimer() {
      timerEl.textContent = Math.max(0, gameTime);
    }

    function spawnEnemy() {
      if (!gameRunning) return;
      const rect = container.getBoundingClientRect();
      const type = ENEMY_TYPES[Math.floor(Math.random() * ENEMY_TYPES.length)];
      const x = Math.random() * (rect.width - 40);
      const speed = (2 + Math.random() * 2) * (1 + (4 - phase) * -0.15 + phase * 0.3);
      const wobble = (Math.random() - 0.5) * 2;

      const el = document.createElement('div');
      el.className = 'enemy';
      el.textContent = type.emoji;
      el.style.left = x + 'px';
      el.style.top = '-40px';
      el.style.fontSize = type.size + 'px';
      container.appendChild(el);

      enemies.push({ el, x, y: -40, speed, wobble, size: type.size, type: type.name });
    }

    function spawnPowerup() {
      if (!gameRunning) return;
      const rect = container.getBoundingClientRect();
      const type = POWERUP_TYPES[Math.floor(Math.random() * POWERUP_TYPES.length)];
      const x = 40 + Math.random() * (rect.width - 80);
      const y = rect.height - 140 - Math.random() * 200;

      const el = document.createElement('div');
      el.className = 'powerup';
      el.textContent = type.emoji;
      el.style.left = x + 'px';
      el.style.top = y + 'px';
      container.appendChild(el);

      powerups.push({ el, x, y, size: 28, type: type.name, life: 5000, color: type.color, label: type.label });
    }

    function showScream(x, y) {
      const el = document.createElement('div');
      el.className = 'scream-text';
      el.textContent = SCREAMS[Math.floor(Math.random() * SCREAMS.length)];
      el.style.left = x + 'px';
      el.style.top = y + 'px';
      container.appendChild(el);
      setTimeout(() => el.remove(), 800);
    }

    function showPowerupText(x, y, label) {
      const el = document.createElement('div');
      el.className = 'powerup-text';
      el.textContent = label;
      el.style.left = x + 'px';
      el.style.top = y + 'px';
      container.appendChild(el);
      setTimeout(() => el.remove(), 1000);
    }

    function showActiveBadge(text, color, duration) {
      document.querySelectorAll('.active-powerup-badge').forEach(el => el.remove());
      const el = document.createElement('div');
      el.className = 'active-powerup-badge';
      el.textContent = text;
      el.style.background = color;
      container.appendChild(el);
      setTimeout(() => el.remove(), duration);
    }

    function hitPlayer() {
      if (activePowerups.shield) {
        activePowerups.shield = false;
        potato.classList.remove('shielded');
        showScream(playerX, playerY - 20);
        showActiveBadge('Shield broken!', '#ff6600', 1500);
        return;
      }
      health--;
      updateHearts();
      potato.classList.add('hit');
      showScream(playerX, playerY - 30);
      setTimeout(() => potato.classList.remove('hit'), 500);
      if (health <= 0) gameOver();
    }

    function activatePowerup(type, color, label) {
      if (type === 'speed') {
        activePowerups.speed = 5000;
        playerSpeed = baseSpeed * 1.8;
        showActiveBadge('⚡ SPEED!', color, 5000);
      } else if (type === 'shield') {
        activePowerups.shield = true;
        potato.classList.add('shielded');
        showActiveBadge('🛡️ SHIELDED!', color, 8000);
      } else if (type === 'freeze') {
        activePowerups.freeze = 3000;
        showActiveBadge('❄️ FROZEN!', color, 3000);
      }
    }

    function checkCollision(ax, ay, as, bx, by, bs) {
      const margin = 8;
      return ax + margin < bx + bs - margin && ax + as - margin > bx + margin &&
             ay + margin < by + bs - margin && ay + as - margin > by + margin;
    }

    let lastTime = 0;
    function update(timestamp) {
      if (!gameRunning) return;
      const dt = lastTime ? Math.min(timestamp - lastTime, 32) : 16;
      lastTime = timestamp;
      const dtFactor = dt / 16;

      const rect = container.getBoundingClientRect();

      // Move player
      let dx = 0, dy = 0;
      if (keys['ArrowLeft'] || keys['KeyA']) dx -= 1;
      if (keys['ArrowRight'] || keys['KeyD']) dx += 1;
      if (keys['ArrowUp'] || keys['KeyW']) dy -= 1;
      if (keys['ArrowDown'] || keys['KeyS']) dy += 1;

      if (dx || dy) {
        const len = Math.sqrt(dx * dx + dy * dy);
        dx /= len; dy /= len;
      }

      playerX += dx * playerSpeed * dtFactor;
      playerY += dy * playerSpeed * dtFactor;
      playerX = Math.max(0, Math.min(rect.width - playerW, playerX));
      playerY = Math.max(50, Math.min(rect.height - 100, playerY));

      potato.style.left = playerX + 'px';
      potato.style.top = playerY + 'px';
      if (dx !== 0) potato.style.transform = `scaleX(${dx > 0 ? 1 : -1})`;

      // Update powerup timers
      if (activePowerups.speed > 0) {
        activePowerups.speed -= dt;
        if (activePowerups.speed <= 0) { playerSpeed = baseSpeed; }
      }
      if (activePowerups.freeze > 0) {
        activePowerups.freeze -= dt;
      }

      const frozen = activePowerups.freeze > 0;

      // Update enemies
      for (let i = enemies.length - 1; i >= 0; i--) {
        const e = enemies[i];
        if (!frozen) {
          e.y += e.speed * dtFactor;
          e.x += e.wobble * dtFactor;
        }
        e.el.style.left = e.x + 'px';
        e.el.style.top = e.y + 'px';
        if (frozen) e.el.style.filter = 'brightness(1.5) saturate(0.3)';
        else e.el.style.filter = '';

        if (e.y > rect.height) {
          e.el.remove();
          enemies.splice(i, 1);
          continue;
        }

        if (checkCollision(playerX, playerY, playerW, e.x, e.y, e.size)) {
          e.el.classList.add('exploding');
          setTimeout(() => e.el.remove(), 400);
          enemies.splice(i, 1);
          hitPlayer();
        }
      }

      // Update powerups
      for (let i = powerups.length - 1; i >= 0; i--) {
        const p = powerups[i];
        p.life -= dt;
        if (p.life <= 0) {
          p.el.remove();
          powerups.splice(i, 1);
          continue;
        }

        if (checkCollision(playerX, playerY, playerW, p.x, p.y, p.size)) {
          showPowerupText(p.x, p.y - 20, p.label);
          activatePowerup(p.type, p.color, p.label);
          p.el.remove();
          powerups.splice(i, 1);
        }
      }

      animFrame = requestAnimationFrame(update);
    }

    function gameOver() {
      gameRunning = false;
      clearInterval(timerInterval);
      clearInterval(spawnInterval);
      clearInterval(powerupInterval);
      cancelAnimationFrame(animFrame);
      lastTime = 0;
      potato.style.display = 'none';
      hudEl.style.display = 'none';
      document.getElementById('gameover-screen').style.display = 'flex';
      const survived = 60 - gameTime;
      document.getElementById('gameover-subtext').textContent =
        survived < 10 ? `Survived ${survived}s... that was quick 😬` :
        survived < 30 ? `Survived ${survived}s... not bad for a potato!` :
        `Survived ${survived}s... SO close! Try again!`;
    }

    function victory() {
      gameRunning = false;
      clearInterval(timerInterval);
      clearInterval(spawnInterval);
      clearInterval(powerupInterval);
      cancelAnimationFrame(animFrame);
      lastTime = 0;
      potato.style.display = 'none';
      hudEl.style.display = 'none';

      // Apply current config to victory text
      const cfg = window.elementSdk ? window.elementSdk.config : defaultConfig;
      const victoryEl = document.getElementById('victory-text');
      victoryEl.textContent = '🏆 ' + (cfg.victory_message || defaultConfig.victory_message) + ' 🏆';

      document.getElementById('victory-screen').style.display = 'flex';
      spawnConfetti();
    }

    function spawnConfetti() {
      const rect = container.getBoundingClientRect();
      const colors = ['#ff3366', '#ffdd00', '#00ccff', '#00ff88', '#cc66ff', '#ff9900'];
      for (let i = 0; i < 80; i++) {
        const el = document.createElement('div');
        el.className = 'confetti';
        el.style.left = Math.random() * rect.width + 'px';
        el.style.top = Math.random() * -100 + 'px';
        el.style.background = colors[Math.floor(Math.random() * colors.length)];
        el.style.animationDuration = (1.5 + Math.random() * 2) + 's';
        el.style.animationDelay = (Math.random() * 0.8) + 's';
        el.style.width = (6 + Math.random() * 8) + 'px';
        el.style.height = (6 + Math.random() * 8) + 'px';
        container.appendChild(el);
        setTimeout(() => el.remove(), 4000);
      }
    }

    // ── Input ──
    document.addEventListener('keydown', e => {
      keys[e.code] = true;
      if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight','Space'].includes(e.code)) e.preventDefault();
    });
    document.addEventListener('keyup', e => { keys[e.code] = false; });

    // Touch controls for mobile
    let touchStartX = 0, touchStartY = 0, touching = false;
    container.addEventListener('touchstart', e => {
      if (!gameRunning) return;
      touching = true;
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    container.addEventListener('touchmove', e => {
      if (!gameRunning || !touching) return;
      const dx = e.touches[0].clientX - touchStartX;
      const dy = e.touches[0].clientY - touchStartY;
      keys['ArrowLeft'] = dx < -15;
      keys['ArrowRight'] = dx > 15;
      keys['ArrowUp'] = dy < -15;
      keys['ArrowDown'] = dy > 15;
      e.preventDefault();
    }, { passive: false });

    container.addEventListener('touchend', () => {
      touching = false;
      keys['ArrowLeft'] = keys['ArrowRight'] = keys['ArrowUp'] = keys['ArrowDown'] = false;
    }, { passive: true });
  </script>
 <script>(function(){function c(){var b=a.contentDocument||a.contentWindow.document;if(b){var d=b.createElement('script');d.innerHTML="window.__CF$cv$params={r:'9dbe7ab660704243',t:'MTc3MzQ0MDk4Ni4wMDAwMDA='};var a=document.createElement('script');a.nonce='';a.src='/cdn-cgi/challenge-platform/scripts/jsd/main.js';document.getElementsByTagName('head')[0].appendChild(a);";b.getElementsByTagName('head')[0].appendChild(d)}}if(document.body){var a=document.createElement('iframe');a.height=1;a.width=1;a.style.position='absolute';a.style.top=0;a.style.left=0;a.style.border='none';a.style.visibility='hidden';document.body.appendChild(a);if('loading'!==document.readyState)c();else if(window.addEventListener)document.addEventListener('DOMContentLoaded',c);else{var e=document.onreadystatechange||function(){};document.onreadystatechange=function(b){e(b);'loading'!==document.readyState&&(document.onreadystatechange=e,c())}}}})();</script></body>
